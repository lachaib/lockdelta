{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "files": {
    "maxSize": 2000000,
    "includes": [
      "**/*", // include everything by default
      "!**/build", // exclude build output
      "!!**/dist", // exclude dist output
      "!!**/node_modules", // exclude dependencies
      "!!**/tests/fixtures", // exclude test fixtures
      "!!**/.claude" // exclude Claude config/memory
    ]
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all"
    }
  }
}
